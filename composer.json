{
  "name": "poldixd/laravel-queue-clear-all",
  "description": "Clear all Laravel Horizon queues with a single Artisan command.",
  "keywords": [
    "artisan",
    "horizon",
    "laravel",
    "queue"
  ],
  "type": "library",
  "license": "MIT",
  "homepage": "https://github.com/poldixd/laravel-queue-clear-all",
  "require": {
    "php": "^8.2",
    "illuminate/support": "^11.0 || ^12.0 || ^13.0",
    "laravel/horizon": "^3.0 || ^4.0 || ^5.0"
  },
  "require-dev": {
    "laravel/pint": "^1.19",
    "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
    "pestphp/pest": "^3.0 || ^4.0",
    "pestphp/pest-plugin-laravel": "^3.0 || ^4.0"
  },
  "authors": [
    {
      "name": "Nils Poltmann",
      "email": "dev@nils.li"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "poldixd\\QueueClearAll\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "poldixd\\QueueClearAll\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "poldixd\\QueueClearAll\\QueueClearAllServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "vendor/bin/pest"
  }
}
